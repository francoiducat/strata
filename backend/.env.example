# Example environment variables for Strata backend
# SQLite (default local dev)
# DATABASE_URL="sqlite://$(pwd)/.data/strata.db"

# Postgres (development with docker-compose)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/strata"

# For Docker Compose service (from repository root):
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/strata"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=strata
