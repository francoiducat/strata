# Example environment variables for Strata backend
# Default environment
ENV=development

# DATABASE_URL examples
# Container (recommended for docker-compose, points at container file)
# DATABASE_URL="sqlite:////app/.data/strata.db"

# Host (use when running on the host with Poetry; expands to a path in the repo)
# DATABASE_URL="sqlite://$(pwd)/.data/strata.db"

# Postgres examples
# Local host (when Postgres is exposed on the host)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5434/strata"

# Docker Compose service (inside the compose network)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/strata"

# Postgres connection defaults (used by the postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=strata
